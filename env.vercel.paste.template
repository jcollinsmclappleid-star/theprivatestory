# 1. Copy this file to .env.vercel.paste (or edit .env.vercel.paste in the repo root)
# 2. Replace PASTE_HERE with values from Replit Secrets
# 3. Tell the agent: "upload vercel secrets" — it reads .env.vercel.paste and pushes to Vercel
#
# .env.vercel.paste is gitignored — never commit it.
# Vercel dashboard (manual alternative):
# https://vercel.com/jcollinsmclappleid-stars-projects/theprivatestory/settings/environment-variables

OPENAI_API_KEY=PASTE_HERE
AI_INTEGRATIONS_OPENAI_API_KEY=PASTE_HERE
AI_INTEGRATIONS_OPENAI_BASE_URL=PASTE_HERE
OPENROUTER_API_KEY=PASTE_HERE
ELEVENLABS_API_KEY=PASTE_HERE
STRIPE_SECRET_KEY=PASTE_HERE
STRIPE_WEBHOOK_SECRET=PASTE_HERE
RESEND_API_KEY=PASTE_HERE
RESEND_DOMAIN_KEY=PASTE_HERE
ADMIN_SCRIPT_KEY=PASTE_HERE
DEFAULT_OBJECT_STORAGE_BUCKET_ID=PASTE_HERE
PRIVATE_OBJECT_DIR=PASTE_HERE
PUBLIC_OBJECT_SEARCH_PATHS=PASTE_HERE
# GCS on Vercel — base64-encode your service account JSON:
#   base64 -i key.json | tr -d '\n'  (macOS)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=PASTE_HERE
SESSION_SECRET=PASTE_HERE

# Optional — Google sign-in (leave PASTE_HERE if you don't use it)
GOOGLE_CLIENT_ID=PASTE_HERE
GOOGLE_CLIENT_SECRET=PASTE_HERE
