{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash ../../scripts/dev-local.sh",
    "serve": "bash ../../scripts/dev-local.sh",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "convert-act4-webp": "node ./scripts/convertExpressAct4ToWebp.mjs",
    "qa:attr:generate": "ATTRIBUTION_QA=1 LOCAL_AUDIO_MIRROR=1 SKIP_GCS_UPLOAD=1 tsx scripts/generate-attribution-snippet-audio.mts --all",
    "qa:attr:verify": "tsx scripts/verify-attribution-audio.mts --all",
    "test:dialogue-attribution": "tsx scripts/dialogueAttribution.test.mts",
    "test:story-length": "tsx scripts/storyLength.test.mts",
    "test:dialogue-vocal": "tsx scripts/dialogue-vocal.test.mts",
    "test:customer-desire": "tsx scripts/customerDesireBeats.test.mts",
    "test:enactment-constraints": "tsx scripts/enactmentConstraints.test.mts",
    "test:express-brief": "tsx scripts/expressBrief.test.mts",
    "test:express-scene-plan": "tsx scripts/expressScenePlan.test.mts",
    "story:fantasy-e2e": "tsx scripts/story-fantasy-e2e.mts",
    "story:extreme-e2e": "tsx scripts/story-extreme-e2e.mts",
    "pilot:vocal-v3": "VOCAL_EFFECTS=1 LOCAL_AUDIO_MIRROR=1 tsx scripts/pilot-vocal-v3.mts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@replit/connectors-sdk": "^0.3.0",
    "@types/nodemailer": "^7.0.11",
    "@vercel/blob": "^2.5.0",
    "@vercel/functions": "^3.4.2",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "@workspace/intensity": "workspace:*",
    "@workspace/seo-data": "workspace:*",
    "better-auth": "^1.5.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.4",
    "openai": "^6.32.0",
    "openid-client": "^6.8.2",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.9.4",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "sharp": "^0.34.5",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
